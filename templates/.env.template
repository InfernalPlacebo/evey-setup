# ══════════════════════════════════════════════════════════════
# Evey Stack Environment Variables
# Generated by evey-setup — fill in your values below
# ══════════════════════════════════════════════════════════════

# ── REQUIRED ─────────────────────────────────────────────────

# OpenRouter API key (free tier works — get one at https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# LiteLLM master key (auto-generated — change if you want)
LITELLM_MASTER_KEY=sk-evey-CHANGE-ME

# Internal API key for agent server (auto-generated)
API_SERVER_KEY=sk-api-CHANGE-ME

# ── TELEGRAM (optional) ─────────────────────────────────────
# Create a bot via @BotFather on Telegram to get a token
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram user IDs allowed to interact with the bot
# Find your ID via @userinfobot on Telegram
TELEGRAM_ALLOWED_USERS=

# ── TIMEZONE ─────────────────────────────────────────────────
TZ=UTC

# ── CLOUDFLARE AI GATEWAY (optional) ────────────────────────
# Route API traffic through CF for caching, analytics, rate limiting
# CF_ACCOUNT_ID=
# CF_GATEWAY_ID=
# CF_AIG_AUTH_HEADER=Bearer YOUR_TOKEN

# ── OLLAMA (local inference) ────────────────────────────────
# Only needed if running the ollama service
OLLAMA_HOST=http://hermes-ollama:11434

# ── LANGFUSE (optional — cost tracking & observability) ─────
# LANGFUSE_PUBLIC_KEY=pk-local
# LANGFUSE_SECRET_KEY=sk-local
# LANGFUSE_ADMIN_PASSWORD=CHANGE-ME
# NEXTAUTH_SECRET=CHANGE-ME
# LANGFUSE_SALT=CHANGE-ME

# ── ADDITIONAL API KEYS (optional) ──────────────────────────
# Nous Research portal ($0.09/M tokens for Hermes models)
# NOUS_API_KEY=

# Anthropic (for Claude models via LiteLLM)
# ANTHROPIC_API_KEY=

# Google (for Gemini models)
# GEMINI_API_KEY=

# ── UPTIME KUMA (optional) ──────────────────────────────────
# UPTIME_KUMA_USER=admin
# UPTIME_KUMA_PASS=CHANGE-ME

# ── NTFY (optional — push notifications) ────────────────────
# NTFY_TOPIC=my-agent-alerts

# ── N8N (optional — workflow automation) ─────────────────────
# N8N_USER=admin@example.com
# N8N_PASS=CHANGE-ME

# ── RESEND (optional — transactional email) ──────────────────
# RESEND_API_KEY=

# ── GITHUB (optional — for plugins, repos) ──────────────────
# GITHUB_PAT=

# ── DISCORD (optional) ──────────────────────────────────────
# DISCORD_BOT_TOKEN=
